{
  "name": "赛博乞讨站",
  "short_name": "赛博乞讨",
  "description": "一个赛博朋克风格的乞讨网站",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ebf1d6",
  "theme_color": "#a8cda2",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "categories": ["utilities", "productivity"],
  "screenshots": [
    {
      "src": "/screenshot1.png",
      "sizes": "540x720",
      "type": "image/png"
    }
  ],
  "shortcuts": [
    {
      "name": "快速施舍",
      "short_name": "施舍",
      "description": "快速打赏",
      "url": "/?action=donate",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/?share-target=true",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", "video/*", "audio/*"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+cyberbeggar",
      "url": "/?handler=%s"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false
}
